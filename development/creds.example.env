################################################################################
# CREDS File: Store private information. Copied to creds.env and always ignored
################################################################################

# Context name for invoke task.py, invoke.yml
CONFIGURATION_NAMESPACE=nautobot_app_livedata

# Nautobot Configuration Secret Items
NAUTOBOT_CREATE_SUPERUSER=true
NAUTOBOT_DB_PASSWORD=changeme_db_password
NAUTOBOT_NAPALM_USERNAME=''
NAUTOBOT_NAPALM_PASSWORD=''
NAUTOBOT_REDIS_PASSWORD=changeme
NAUTOBOT_SECRET_KEY='changeme'
NAUTOBOT_SUPERUSER_NAME=admin
NAUTOBOT_SUPERUSER_EMAIL=admin@example.com
NAUTOBOT_SUPERUSER_PASSWORD=admin
NAUTOBOT_SUPERUSER_API_TOKEN=0123456789abcdef0123456789abcdef01234567

# Postgres
POSTGRES_PASSWORD=changeme_db_password
PGPASSWORD=changeme_db_password

# MySQL Credentials - use explicit values, Docker env_file doesn't expand variables reliably
MYSQL_ROOT_PASSWORD=changeme_db_password

# Use these to override values in development.env
# NAUTOBOT_DB_HOST=localhost
# NAUTOBOT_REDIS_HOST=localhost
# NAUTOBOT_CONFIG=development/nautobot_config.py

# Additional placeholders generated from creds.env
